# GAUNTLEX — environment configuration template
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Model Providers (set ONE to activate it) ──────────────────────────────────
# Priority: OPENROUTER_API_KEY > ANTHROPIC_API_KEY > HF_TOKEN > Ollama (default)

# OpenRouter — free & paid open-source models
# Get a free key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Best free models (uncomment to override the default):
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free   ← recommended (70B, reliable JSON)
# OPENROUTER_MODEL=qwen/qwen3-coder:free                    ← best for code analysis
# OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-405b:free ← most capable free model
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace Serverless Inference API
# HF_TOKEN=hf_...
# HF_MODEL=meta-llama/Llama-3.1-70B-Instruct

# Generic OpenAI-compatible (vLLM, Together AI, Groq, Azure OpenAI, etc.)
# OPENAI_COMPAT_BASE_URL=https://api.together.xyz/v1
# OPENAI_COMPAT_API_KEY=
# OPENAI_COMPAT_MODEL=meta-llama/Llama-3-70b-chat-hf

# ── Threat Intelligence (optional — enriches Breaker context with live CVE data) ─
# CISA KEV feed is always-on, free, no key required.
# NIST NVD requires a free API key for higher rate limits (5/30s without key).
# Get a free NVD key: https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=

# ── CPaaS — GitHub App (optional, for gauntlex serve) ─────────────────────────
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY_PATH=./gauntlex-app.private-key.pem
# GITHUB_WEBHOOK_SECRET=
# GITHUB_TOKEN=

# ── Service ───────────────────────────────────────────────────────────────────
# GAUNTLEX_SERVICE_PORT=8080
# GAUNTLEX_MODE=standard
# GAUNTLEX_MIN_ARS=0.80
